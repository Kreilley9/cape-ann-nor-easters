# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Supabase PostgreSQL connection string — find under Project Settings > Database)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Email (Resend)
RESEND_API_KEY=re_your_key

# SMS (Twilio — optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# App
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Vite (frontend — prefix with VITE_ so Vite exposes them to the browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_ASSETS_BASE_URL=https://your-project.supabase.co/storage/v1/object/public/assets
